  "metadata": {
    "version": "1.3",
    "description": "Rendements optimaux + charges opérationnelles par hectare selon le type de sol (France). Rendement à pondérer par le score de risque météo IA.",
    "pays": "France",
    "annee_reference": 2022,
    "devise": "EUR",
    "types_sol": {
      "argileux": "Rétention eau élevée, labour difficile, mécanisation plus lourde. Favorise blé, colza, betterave.",
      "limoneux": "Sol de référence, structure idéale, charges standard. Polyvalent.",
      "sableux": "Drainage rapide, engrais lessivés, irrigation souvent nécessaire. Favorable pomme de terre, soja."
    },
    "charges_incluses": [
      "semences",
      "engrais (N, P, K)",
      "phytosanitaires (herbicides, fongicides, insecticides)",
      "mécanisation (travail du sol, semis, récolte, transport)",
      "irrigation (si applicable selon sol et culture)",
      "divers (assurance, conseil, analyses sol)"
    ],
    "charges_non_incluses": [
      "fermage / foncier",
      "amortissement matériel",
      "main d'oeuvre salariée",
      "charges de structure"
    ],
    "formule_marge_brute": "MB (€/ha) = (rendement_optimal_t_ha * facteur_risque_meteo * prix_vente_t) - charges_ha[type_sol].total",
    "usage_facteur_risque": "facteur_risque_meteo : float entre 0.0 (catastrophe) et 1.0 (conditions idéales), calculé par l'IA"
  }
}